<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<title>Mənim ilk veb saytım</title>

<style>

body{
font-family:Arial;
background-color:#f2f2f2;
text-align: center;
margin:0;
}

header{
background-color:#4CAF50;
color:white;
padding:15px;
}

.kampaniya {
    background: gold;
    padding: 10px;
    text-align: center;
    animation: slideDown 1s ease;
}

@keyframes slideDown {
    from {transform: translateY(-50px); opacity:0;}
    to {transform: translateY(0); opacity:1;}
}

/* ✅ DÜZƏLDİLMİŞ CƏDVƏL */
table {
    width: auto;              /* əsas düzəliş */
    max-width: 600px;
    margin: 20px auto;
    border-collapse: collapse;
    background:white;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
}

th, td {
    border: 1px solid #ddd;
    padding: 6px;
    text-align: center;
}

th {
    background-color:#4CAF50;
    color:white;
}

tr {
    height: 40px;
}

tr:hover {
    background:#f1f1f1;
}

button {
    padding: 7px 12px;
    cursor: pointer;
    border:none;
    background:#4CAF50;
    color:white;
    border-radius:5px;
    transition:0.3s;
}

button:hover {
    background:#45a049;
    transform: scale(1.05);
}

/* FORM ANİMASİYA */
.form-container {
    display: none;
    margin: 20px auto;
    padding: 20px;
    border-radius:10px;
    background: white;
    width: 300px;
    box-shadow:0 0 15px rgba(0,0,0,0.2);
    animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
    from {opacity:0; transform: scale(0.9);}
    to {opacity:1; transform: scale(1);}
}

input {
    padding:8px;
    margin:5px;
    width:90%;
    border:1px solid #ccc;
    border-radius:5px;
    transition:0.3s;
}

input:focus {
    border-color:#4CAF50;
    outline:none;
    box-shadow:0 0 5px #4CAF50;
}

.circle-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    margin-top:10px;
    transition:0.3s;
}

.circle-image:hover {
    transform: scale(1.1);
}

footer {
    background: #333;
    color: white;
    padding: 10px;
    margin-top: 20px;
}
</style>

</head>

<body>

<header>
<h1>IT Academy</h1>
</header>

<div class="kampaniya">
<h2>KAMPANİYA!</h2>
<p>🚀 Kurs müddətinin sonuna qədər ofis proqramları dərsləri hədiyyə verilir 🎯</p>
</div>

<h2>Keçirilən dərslər</h2>

<table>
<tr>
<th>Təlimçi</th>
<th>Kurs</th>
<th>Müddət</th>
<th>Ödəniş</th>
<th>Əməliyyat</th>
</tr>

<tr>
<td>Mustafayeva Səbinə</td>
<td>IT mühəndis</td>
<td>5 ay</td>
<td>210 AZN</td>
<td><button onclick="showForm('form1')">Qeydiyyat</button></td>
</tr>

<tr>
<td>Qarayeva Rahilə</td>
<td>Data Analitika</td>
<td>6 ay</td>
<td>240 AZN</td>
<td><button onclick="showForm('form2')">Qeydiyyat</button></td>
</tr>

<tr>
<td>Məmmədli Günel</td>
<td>Web Proqramlaşdırma</td>
<td>8 ay</td>
<td>230 AZN</td>
<td><button onclick="showForm('form3')">Qeydiyyat</button></td>
</tr>
</table>

<!-- FORMLAR -->

<div id="form1" class="form-container">
<h3>IT mühəndis</h3>
<form onsubmit="submitForm(event)">
<input type="text" placeholder="Ad" required>
<input type="email" placeholder="Email" required>
<input type="number" placeholder="Yaş" min="1" required>

<p>Kurs forması:</p>
<label><input type="radio" name="serait1" required> Əyani</label>
<label><input type="radio" name="serait1"> Online</label>

<br><br>
<button type="submit">Göndər</button>
<button type="button" onclick="hideForms()">Bağla</button>
</form>
</div>

<div id="form2" class="form-container">
<h3>Data Analitika</h3>
<form onsubmit="submitForm(event)">
<input type="text" placeholder="Ad" required>
<input type="email" placeholder="Email" required>
<input type="number" placeholder="Yaş" min="1" required>

<p>Kurs forması:</p>
<label><input type="radio" name="serait2" required> Əyani</label>
<label><input type="radio" name="serait2"> Online</label>

<br><br>
<button type="submit">Göndər</button>
<button type="button" onclick="hideForms()">Bağla</button>
</form>
</div>

<div id="form3" class="form-container">
<h3>Web Proqramlaşdırma</h3>
<form onsubmit="submitForm(event)">
<input type="text" placeholder="Ad" required>
<input type="email" placeholder="Email" required>
<input type="number" placeholder="Yaş" min="1" required>

<p>Kurs forması:</p>
<label><input type="radio" name="serait3" required> Əyani</label>
<label><input type="radio" name="serait3"> Online</label>

<br><br>
<button type="submit">Göndər</button>
<button type="button" onclick="hideForms()">Bağla</button>
</form>
</div>

<h2>Şəkil</h2>
<img src="https://avatars.mds.yandex.net/get-altay/13220782/2a0000018fa2c6b14785674db6f6864c9867/L_height" class="circle-image">

<address>IT Academy kod yazmağı sevərlərin ünvanı</address>

<footer>
<p>2026 © IT Academy</p>
</footer>

<script>
function showForm(formId) {
    const forms = document.querySelectorAll('.form-container');
    forms.forEach(f => f.style.display = 'none');

    document.getElementById(formId).style.display = 'block';

    window.scrollTo({top: document.body.scrollHeight, behavior:'smooth'});
}

function hideForms() {
    const forms = document.querySelectorAll('.form-container');
    forms.forEach(f => f.style.display = 'none');
}

function submitForm(event) {
    event.preventDefault();
    alert("Qeydiyyat tamamlandı!");
    event.target.reset();
    hideForms();
}
</script>

</body>
</html>
